<?xml version="1.0" encoding="utf-8"?>

<!--
    XLumen res/xml/preferences.xml

    Keys must match LumenPrefs constants exactly.
    LumenService re-reads LumenPrefs each sample cycle so changes
    take effect immediately without restarting the service.

    EditTextPreference stores values as strings internally regardless
    of inputType.  LumenPrefs.parseInt() handles the conversion.

    Sample interval: how often to grab a screen frame.
    Stored as string ms.  Range: 3ms to 333ms.  Default: 100ms.

    Cooldown: minimum time between flash guard triggers.
    Stored as string ms.  Range: 500ms to 30000ms.  Default: 3000ms.

    Threshold: fraction of sampled pixels that must be near-white
    to trigger flash guard.  Stored as string int 1-99.
    LumenPrefs.getThreshold() divides by 100.  Default: 10 (= 10%).

    Flash guard enabled: master toggle for flash detection and response.
    CheckBoxPreference, stored as boolean.  Default: true.

    Flash guard brightness: SCREEN_BRIGHTNESS value slammed on trigger.
    Stored as string int 0-255.  Default: 10.
    Only applied if write_settings_trusted is true and permission granted.

    Pixel sample mode: STRIDE_65 samples one pixel per 65, fast and
    sufficient for full-screen flashes.  FULL scans every pixel,
    exhaustive, use for diagnostics only.
    ListPreference, stored as string.  Default: STRIDE_65.

    Write settings trusted: gates SCREEN_BRIGHTNESS hammering.
    CheckBoxPreference, stored as boolean.  Default: false.
    Flipping this on fires ACTION_MANAGE_WRITE_SETTINGS if not yet granted.
-->

<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">

    <EditTextPreference
        android:key="sample_interval_ms"
        android:title="Sample interval (ms)"
        android:summary="50ms default"
        android:defaultValue="50"
        android:inputType="number" />

    <EditTextPreference
        android:key="cooldown_ms"
        android:title="Flash guard cooldown (ms)"
        android:summary="1000ms default"
        android:defaultValue="1000"
        android:inputType="number" />

    <EditTextPreference
        android:key="threshold"
        android:title="Flash trigger threshold (%)"
        android:summary="45% default"
        android:defaultValue="45"
        android:inputType="number" />

    <CheckBoxPreference
        android:key="flashguard_enabled"
        android:title="Flash guard"
        android:summary="Slam overlay and brightness on sudden bright flash"
        android:defaultValue="true" />

    <ListPreference
        android:key="pixel_sample_mode"
        android:title="Pixel sampling mode"
        android:summary="STRIDE_65 is faster.  FULL is exhaustive."
        android:entries="@array/pixel_sample_mode_entries"
        android:entryValues="@array/pixel_sample_mode_values"
        android:defaultValue="STRIDE_65" />

    <CheckBoxPreference
        android:key="write_settings_trusted"
        android:title="Allow system brightness control"
        android:summary="Requires &apos;Modify system settings&apos; permission.  Tap to enable, then grant in the system dialog that follows."
        android:defaultValue="false" />

    <EditTextPreference
        android:key="flashguard_brightness"
        android:title="Flash guard brightness floor (0-255)"
        android:summary="System brightness slammed to this on trigger.  Default: 1"
        android:defaultValue="1"
        android:inputType="number" />

    <ListPreference
        android:key="brightness_log_interval_ms"
        android:title="Brightness calibration log interval"
        android:summary="Log brightness and overlay data for calibration."
        android:entries="@array/brightness_log_interval_entries"
        android:entryValues="@array/brightness_log_interval_values"
        android:defaultValue="60000" />

</PreferenceScreen>