<?xml version="1.0" encoding="utf-8"?>

<!--
    XLumen main activity layout.

    Intentionally minimal - most users never open this after initial setup.
    Real interaction is via the Quick Settings tile.

    Views:
        txt_a11y_status  - warns user if accessibility service is not enabled
        txt_status       - current service state (running / stopped)
        btn_start_stop   - requests MediaProjection permission and starts service
        btn_settings     - opens SettingsActivity
-->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/txt_a11y_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:paddingBottom="16dp"
        android:text="Checking accessibility service..." />

    <TextView
        android:id="@+id/txt_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:paddingBottom="24dp"
        android:text="XLumen stopped." />

    <Button
        android:id="@+id/btn_start_stop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings" />

    <TextView
        android:id="@+id/txt_debug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:paddingTop="24dp"
        android:text="" />

    <Button
        android:id="@+id/btn_read_debug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Read Debug Log" />

</LinearLayout>